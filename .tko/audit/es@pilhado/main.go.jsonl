{"ts":1783209874,"hash":"9448a0e917560eddd7b43323fe205e524ad261ccc49993d285b771d308c47ff9","mode":"diff","ops":[{"tag":"insert","a1":11,"a2":11,"text":"// ---- Simulando a estrutura de Stack para compilação ----\ntype Stack[T any] struct {\n\telements []T\n}\n\nfunc NewStack[T any]() *Stack[T] { return &Stack[T]{elements: []T{}} }\nfunc (s *Stack[T]) Push(v T)     { s.elements = append(s.elements, v) }\nfunc (s *Stack[T]) Pop() T {\n\tv := s.elements[len(s.elements)-1]\n\ts.elements = s.elements[:len(s.elements)-1]\n\treturn v\n}\nfunc (s *Stack[T]) Top() T        { return s.elements[len(s.elements)-1] }\nfunc (s *Stack[T]) IsEmpty() bool { return len(s.elements) == 0 }\n\n// --------------------------------------------------------\n\n"},{"tag":"insert","a1":12,"a2":12,"text":"\tif len(grid) == 0 {\n\t\treturn grid\n\t}\n\n"},{"tag":"insert","a1":15,"a2":15,"text":"\t// 1. Encontra o ponto de início 'I'\n"},{"tag":"delete","a1":17,"a2":18,"text":""},{"tag":"replace","a1":20,"a2":22,"text":"\t\t\t\tbreak\n"},{"tag":"insert","a1":23,"a2":23,"text":"\t\t}\n\t\tif !caminho.IsEmpty() {\n\t\t\tbreak\n\t\t}\n\t}\n"},{"tag":"replace","a1":24,"a2":29,"text":"\t// 2. Loop de exploração do labirinto\n\tfor !caminho.IsEmpty() {\n\t\ttop := caminho.Top()\n"},{"tag":"replace","a1":30,"a2":34,"text":"\t\t// Se chegamos na borda do labirinto (e não é o início 'I'), achamos uma saída!\n\t\tif (top.l == 0 || top.l == len(grid)-1 || top.c == 0 || top.c == len(grid[0])-1) && grid[top.l][top.c] != 'I' {\n\t\t\tgrid[top.l][top.c] = '.'\n\t\t\tbreak\n\t\t}\n"},{"tag":"replace","a1":35,"a2":40,"text":"\t\t// Marca a posição atual como visitada (caminho percorrido)\n\t\tif grid[top.l][top.c] == ' ' {\n\t\t\tgrid[top.l][top.c] = '.'\n\t\t}\n"},{"tag":"replace","a1":41,"a2":42,"text":"\t\tvizinhos := []Pos{\n\t\t\t{l: top.l + 1, c: top.c},\n\t\t\t{l: top.l - 1, c: top.c},\n\t\t\t{l: top.l, c: top.c + 1},\n\t\t\t{l: top.l, c: top.c - 1},\n\t\t}\n"},{"tag":"insert","a1":43,"a2":43,"text":"\t\tachaAvanco := false\n\n\t\tfor i := range vizinhos {\n\t\t\tv := vizinhos[i]\n\n\t\t\t// Valida se o vizinho está dentro das fronteiras da matriz\n\t\t\tif v.l >= 0 && v.l < len(grid) && v.c >= 0 && v.c < len(grid[0]) {\n\t\t\t\t// Se for um caminho livre ou uma saída válida, nós avançamos para lá\n\t\t\t\tif grid[v.l][v.c] == ' ' || grid[v.l][v.c] == 'S' { // Ajuste 'S' se houver caractere de saída\n\t\t\t\t\tcaminho.Push(v)\n\t\t\t\t\tachaAvanco = true\n\t\t\t\t\tbreak // Para o loop de vizinhos para processar o novo topo da pilha\n"},{"tag":"insert","a1":45,"a2":45,"text":"\t\t}\n\n\t\t// Se olhou todos os vizinhos e não achou nenhum lugar para avançar, é um beco sem saída\n\t\tif !achaAvanco {\n\t\t\tbeco.Push(caminho.Pop())\n"},{"tag":"replace","a1":53,"a2":54,"text":"\tif _, err := fmt.Scan(&l, &c); err != nil {\n\t\treturn\n\t}\n\n"},{"tag":"replace","a1":55,"a2":56,"text":"\tfor i := range labirinto {\n"},{"tag":"replace","a1":59,"a2":64,"text":"\t// Leitura segura linha por linha (evita problemas com o '\\n')\n\tfor i := 0; i < l; i++ {\n\t\tvar linha string\n\t\tfmt.Scan(&linha)\n\t\tfor j, r := range linha {\n\t\t\tif j < c {\n\t\t\t\tlabirinto[i][j] = r\n\t\t\t}\n"},{"tag":"insert","a1":67,"a2":67,"text":"\tfmt.Println()\n"},{"tag":"delete","a1":68,"a2":69,"text":""},{"tag":"replace","a1":74,"a2":75,"text":"\t\t\tfmt.Printf(\"%c\", grid[l][c])\n"}]}
