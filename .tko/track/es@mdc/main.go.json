            "content": "package main\n\nimport (\n\t\"fmt\"\n)\n\nfunc minmdc(arr []int) int {\n\tv := arr[0]\n\tfor i := range arr {\n\t\tif v < arr[i] {\n\t\t\tv = arr[i]\n\t\t}\n\t}\n\treturn v\n}\n\nfunc mdc(a, b, x int, arr []int) []int {\n\tx++\n\tif a == 1 || b == 1 {\n\t\treturn arr\n\t}\n\n\tif a%x == 0 && b%x == 0 {\n\t\tarr = append(arr, x)\n\t}\n\n\tif a%x == 0 {\n\t\ta = a / x\n\t}\n\n\tif b%x == 0 {\n\t\tb = b / x\n\t}\n\n\treturn mdc(a, b, x, arr)\n}\n\nfunc main() {\n\tvar a, b int\n\tfmt.Scan(&a, &b)\n\tarr := []int{1}\n\tvalues := mdc(a, b, 1, arr)\n\tfmt.Println(minmdc(values))\n}\n",
